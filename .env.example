# ============================================================
# Supabase — safe to expose to frontend (anon key + URL)
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# Server-side only — NEVER use VITE_ prefix for these
# Set these in Vercel Project Settings → Environment Variables
# ============================================================

# Supabase service role key (bypasses RLS — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Same URL as above but for server-side API functions
SUPABASE_URL=https://your-project.supabase.co

# Admin password for the secret blog admin panel
# Choose a strong password — only Dr. Prasanna will know this
ADMIN_PASSWORD=choose-a-strong-password-here
